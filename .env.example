# Required for the LLM-based router and Claude Code adapter
ANTHROPIC_API_KEY=sk-ant-...

# Optional — only needed if using PythonFrameworkAdapter with OpenAI-backed agents
OPENAI_API_KEY=

# Default model used by the router and Claude Code adapter
FORGENT_MODEL=claude-opus-4-6
FORGENT_ROUTER_MODEL=claude-haiku-4-5-20251001

# Path to the SQLite state DB (created on first run)
FORGENT_DB=./forgent.db
